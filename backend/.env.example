DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
FRONTEND_ORIGIN=http://localhost:3000
APP_NAME=Exicom Order Form Service
# Password for the Catalog / Pricing admin area (server-side only, never sent to the browser).
ADMIN_PASSWORD=change-me

# SMTP for login OTP emails. Leave SMTP_HOST blank to skip real sending — the
# OTP is printed to the server log instead, so login stays testable without it.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Exicom Quote Form <no-reply@exicom.in>
